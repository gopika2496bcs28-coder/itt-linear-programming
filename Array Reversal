#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;   
    if (scanf("%d", &n) != 1) {
        return 1;
    }
    int *arr = (int *)malloc(n * sizeof(int));
    if (arr == NULL) {
        return 1; 
    }
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    int start = 0;
    int end = n - 1;
    while (start < end) {
        int temp = arr[start];
        arr[start] = arr[end];
        arr[end] = temp;
        start++;
        end--;
    }
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
    free(arr);

    return 0;
}
